vector<int> spf, primes;
void linSieve(int n) {
    spf.assign(n+1, 0); 

    for (int i = 2; i <= n; ++i) {
        if (!spf[i]) primes.push_back(spf[i] = i);
        for (int j: primes) {
            if (j * i > n) continue;
            spf[i * j] = j;
            if (spf[j] == i) break;
        }
    }
}
